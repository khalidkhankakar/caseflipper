{
  "name": "caseflipper",
  "version": "1.0.0",
  "description": "A package that converts a string into different casing formats",
  "keywords": [
    "caseflipper",
    "casing",
    "string manipulation"
  ],
  "scripts": {
    "build": "tsc",
    "ci": "npm run build && npm run check-format && npm run test",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "test": "vitest",
    "dev": "vitest"
  },
  "homepage": "https://github.com/khalidkhankakar/caseflipper",
  "bugs": {
    "url": "https://github.com/khalidkhankakar/caseflipper"
  },
  "author": "Khalid Kakar <khalidkhankakar2468@gmail.com> (https://khalidkakar.pro)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khalidkhankakar/caseflipper.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
